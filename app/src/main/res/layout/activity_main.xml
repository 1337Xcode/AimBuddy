<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#111827">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1F2937"
        android:padding="20dp"
        android:layout_marginBottom="20dp"
        android:layout_marginHorizontal="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Root Aimbot"
            android:textSize="30sp"
            android:textColor="#F9FAFB"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="ESP + Aimbot (phone-optimized)"
            android:textSize="14sp"
            android:textColor="#9CA3AF" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Status: Idle"
            android:textSize="13sp"
            android:textColor="#93C5FD" />
    </LinearLayout>

    <Button
        android:id="@+id/startButton"
        android:layout_width="260dp"
        android:layout_height="58dp"
        android:text="START"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:backgroundTint="#22C55E"
        android:textColor="#052E16"
        android:layout_marginBottom="14dp" />

    <Button
        android:id="@+id/stopButton"
        android:layout_width="260dp"
        android:layout_height="58dp"
        android:text="STOP"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:backgroundTint="#EF4444"
        android:textColor="#FEE2E2"
        android:enabled="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Drag the floating icon to move menu • tap to open settings"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:layout_marginTop="30dp" />

</LinearLayout>
